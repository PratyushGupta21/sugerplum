{
  "name": "sugar-plum-bakery",
  "version": "1.0.0",
  "description": "Full-stack e-commerce application for Sugar Plum Bakery",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npx live-server --port=3000",
    "start": "npm run start:backend",
    "start:backend": "cd backend && npm start",
    "install:all": "npm install && cd backend && npm install",
    "build": "cd frontend && npm run build",
    "test": "cd backend && npm test",
    "lint": "cd backend && npm run lint",
    "docs": "cd contracts/api && npx swagger-ui-watcher swagger.yaml"
  },
  "keywords": [
    "bakery",
    "e-commerce",
    "full-stack",
    "nodejs",
    "express",
    "mongodb",
    "react"
  ],
  "author": "Sugar Plum Bakery Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^7.6.0",
    "live-server": "^1.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/username/sugar-plum-bakery.git"
  },
  "bugs": {
    "url": "https://github.com/username/sugar-plum-bakery/issues"
  },
  "homepage": "https://github.com/username/sugar-plum-bakery#readme"
}